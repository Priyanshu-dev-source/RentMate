// ─────────────────────────────────────────────────────────────────────
// Rent & Flatmate Finder — Prisma Schema (Phase 2 - Database Layer)
// ─────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

// Ensure database URL points to our Postgres instance
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════

enum UserRole {
  OWNER
  TENANT
  ADMIN
}

enum ListingStatus {
  DRAFT
  ACTIVE
  FILLED
  ARCHIVED
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  CONDO
  VILLA
  PG
}

enum RoomType {
  ENTIRE
  PRIVATE
  SHARED
}

enum InterestStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum NotificationType {
  INTEREST_RECEIVED
  INTEREST_ACCEPTED
  INTEREST_REJECTED
  NEW_MESSAGE
  LISTING_APPROVED
  LISTING_REJECTED
  SYSTEM
}

// ═══════════════════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════════════════

/// Core user account representing identity and authentication.
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatar       String?
  bio          String?
  role         UserRole  @default(TENANT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  ownerProfile         OwnerProfile?
  tenantProfile        TenantProfile?
  chatRoomParticipants ChatRoomParticipant[]
  sentMessages         Message[]             @relation("SentMessages")
  notifications        Notification[]
  adminLogs            AdminLog[]
  savedListings        SavedListing[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

/// Profile information specific to owners (landlords).
model OwnerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  companyName String?
  taxId       String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@map("owner_profiles")
}

/// Profile information, lifestyle habits, and search parameters for tenants.
model TenantProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  cleanliness   Int?     @default(3) // 1-5 scale
  sleepSchedule String? // "early_bird", "night_owl", "flexible"
  smoking       Boolean  @default(false)
  pets          Boolean  @default(false)
  drinking      Boolean  @default(false)
  guestPolicy   String? // "never", "occasionally", "frequently"
  noiseLevel    String? // "quiet", "moderate", "lively"
  diet          String? // "vegetarian", "vegan", "non_vegetarian", "any"
  workSchedule  String? // "wfh", "office", "hybrid"
  budgetMin     Int?
  budgetMax     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  interestRequests       InterestRequest[]
  compatibilities        Compatibility[] @relation("TenantCompatibilities")
  matchedCompatibilities Compatibility[] @relation("TargetTenantCompatibilities")

  @@map("tenant_profiles")
}

/// A room or property listing posted by an owner.
model Listing {
  id            String        @id @default(uuid())
  ownerId       String
  title         String
  description   String
  price         Int           // Monthly rent in cents or smallest currency unit
  deposit       Int?
  propertyType  PropertyType
  roomType      RoomType
  status        ListingStatus @default(DRAFT)

  // Location
  address       String
  city          String
  state         String
  zipCode       String?
  country       String        @default("India")
  latitude      Float?
  longitude     Float?

  // Details
  bedrooms      Int           @default(1)
  bathrooms     Int           @default(1)
  area          Int?          // Square feet
  furnishing    String?       // "furnished", "semi_furnished", "unfurnished"
  availableFrom DateTime      @default(now())
  maxOccupants  Int           @default(1)

  // Rules & Amenities (stored as JSON arrays/string arrays)
  amenities     String[]      @default([])
  rules         String[]      @default([])

  // Metadata
  viewCount     Int           @default(0)
  isFeatured    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  // Relations
  owner            OwnerProfile      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images           ListingImage[]
  interestRequests InterestRequest[]
  compatibilities  Compatibility[]
  savedBy          SavedListing[]

  @@index([ownerId])
  @@index([status])
  @@index([city])
  @@index([price])
  @@index([propertyType])
  @@index([roomType])
  @@index([createdAt])
  @@map("listings")
}

/// Image assets associated with a listing.
model ListingImage {
  id        String   @id @default(uuid())
  listingId String
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

/// Compatibility scores between a tenant profile and another tenant profile, or between a tenant profile and a listing.
model Compatibility {
  id              String   @id @default(uuid())
  tenantProfileId String
  targetTenantId  String?
  targetListingId String?
  score           Float    // Compatibility percentage/score (e.g. 0 to 100)
  details         Json?    // Detailed match breakdowns
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tenantProfile TenantProfile  @relation("TenantCompatibilities", fields: [tenantProfileId], references: [id], onDelete: Cascade)
  targetTenant  TenantProfile? @relation("TargetTenantCompatibilities", fields: [targetTenantId], references: [id], onDelete: Cascade)
  targetListing Listing?       @relation(fields: [targetListingId], references: [id], onDelete: Cascade)

  @@index([tenantProfileId])
  @@index([targetTenantId])
  @@index([targetListingId])
  @@map("compatibilities")
}

/// Tenant expressing interest in renting a listing.
model InterestRequest {
  id              String         @id @default(uuid())
  tenantProfileId String
  listingId       String
  message         String?
  status          InterestStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  tenant  TenantProfile @relation(fields: [tenantProfileId], references: [id], onDelete: Cascade)
  listing Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([tenantProfileId, listingId])
  @@index([tenantProfileId])
  @@index([listingId])
  @@index([status])
  @@map("interest_requests")
}

/// Bookmarked listings (favorites).
model SavedListing {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("saved_listings")
}

/// A messaging thread/room.
model ChatRoom {
  id        String   @id @default(uuid())
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  participants ChatRoomParticipant[]
  messages     Message[]

  @@map("chat_rooms")
}

/// Join table connecting Users to ChatRooms.
model ChatRoomParticipant {
  id         String    @id @default(uuid())
  chatRoomId String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  // Relations
  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatRoomId, userId])
  @@index([userId])
  @@map("chat_room_participants")
}

/// Direct message sent by a user inside a ChatRoom.
model Message {
  id         String    @id @default(uuid())
  chatRoomId String
  senderId   String
  content    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender   User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatRoomId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

/// In-app real-time notification alerts for users.
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
  @@map("notifications")
}

/// Audit logs tracking administrative actions.
model AdminLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  // Relations
  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_logs")
}

/// Queue of background email notifications with retries.
model EmailQueue {
  id           String    @id @default(uuid())
  to           String
  subject      String
  templateName String
  templateData String    // JSON payload storing contextual variables for templates
  status       String    // "PENDING", "SENT", "FAILED"
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  lastError    String?
  nextRunAt    DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([nextRunAt])
  @@map("email_queue")
}
